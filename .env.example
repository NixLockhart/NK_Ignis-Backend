# ===== 基础配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库 =====
DATABASE_URL=mysql://user:password@localhost:3306/volunteer_db

# ===== JWT =====
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# ===== AI 总开关 =====
ENABLE_AI=false

# ===== AI 功能细粒度开关 =====
ENABLE_AI_DESCRIPTION=false
ENABLE_AI_CHECKIN=false
ENABLE_AI_RECOMMENDATION=false

# ===== Dify 配置 =====
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=your-dify-api-key
